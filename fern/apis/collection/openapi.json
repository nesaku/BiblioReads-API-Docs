{
  "info": {
    "title": "API Endpoints",
    "version": "1.0.0",
    "description": "This collection contains the API endpoints for **BiblioReads** (view more about BiblioReads by visiting the [repo on GitHub](https://github.com/nesaku/BiblioReads)). It covers scraping and search operations across several key domains:\n\n- **Book Search** — Search for books by query (`search-books`, `search-scraper`).\n    \n- **Author Data** — Retrieve author profiles and their associated books (`author-scraper`, `author-books-scraper`).\n    \n- **Similar Books** — Discover books similar to a given title (`similar-scraper`).\n    \n- **Series** — Fetch data about book series (`series-scraper`).\n    \n- **Awards** — Access award winners lists and individual winner pages (`winners-list`, `winner-page`).\n    \n- **Reviews** — Scrape book reviews (`reviews-scraper`).\n    \n- **Public API** — A publicly accessible variant of the author info endpoint (`Public API`).\n    \n\nMost endpoints are POST requests targeting a local development server via the `{{Localhost URL}}` variable, with one endpoint pointing to a `{{Public URL}}` for external access."
  },
  "paths": {
    "/api/author/info": {
      "post": {
        "summary": "author-scraper",
        "responses": {
          "200": {
            "description": "Successful response"
          }
        },
        "description": "Scrapes profile information for a given author. Accepts a POST request with an author identifier and returns details such as biography, genres, and ratings.",
        "operationId": "postApiAuthorInfo",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "queryURL"
                ],
                "properties": {
                  "queryURL": {
                    "type": "string",
                    "format": "uri"
                  }
                }
              },
              "example": {
                "queryURL": "https://www.goodreads.com/author/show/3389.Stephen_King"
              }
            }
          }
        },
        "x-fern-sdk-method-name": "author-scraper"
      }
    },
    "/api/quotes/home": {
      "post": {
        "summary": "quotes-home",
        "responses": {
          "200": {
            "description": "Successful response"
          }
        },
        "description": "Scrapes the list of books written by a specific author. Accepts a POST request with an author identifier and returns a structured list of the author's published works.",
        "operationId": "postApiQuotesHome",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "queryURL"
                ],
                "properties": {
                  "queryURL": {
                    "type": "string",
                    "format": "uri"
                  }
                }
              },
              "example": {
                "queryURL": "https://www.goodreads.com/quotes"
              }
            }
          }
        },
        "x-fern-sdk-method-name": "quotes-home"
      }
    },
    "/api/quotes/slug": {
      "post": {
        "summary": "quotes-search",
        "responses": {
          "200": {
            "description": "Successful response"
          }
        },
        "description": "Scrapes the list of books written by a specific author. Accepts a POST request with an author identifier and returns a structured list of the author's published works.",
        "operationId": "postApiQuotesSlug",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "queryURL"
                ],
                "properties": {
                  "queryURL": {
                    "type": "string",
                    "format": "uri"
                  }
                }
              },
              "example": {
                "queryURL": "https://www.goodreads.com/quotes/tag?id=Sad"
              }
            }
          }
        },
        "x-fern-sdk-method-name": "quotes-search"
      }
    },
    "/api/author/books": {
      "post": {
        "summary": "author-books-scraper",
        "responses": {
          "200": {
            "description": "Successful response"
          }
        },
        "description": "Scrapes the list of books written by a specific author. Accepts a POST request with an author identifier and returns a structured list of the author's published works.",
        "operationId": "postApiAuthorBooks",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "page",
                  "queryURL"
                ],
                "properties": {
                  "page": {
                    "type": "integer"
                  },
                  "queryURL": {
                    "type": "string",
                    "format": "uri"
                  }
                }
              },
              "example": {
                "page": 1,
                "queryURL": "https://www.goodreads.com/author/list/3389.Stephen_King"
              }
            }
          }
        },
        "x-fern-sdk-method-name": "author-books-scraper"
      }
    },
