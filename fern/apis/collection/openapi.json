    "/api/search/books": {
      "post": {
        "summary": "search-books",
        "responses": {
          "200": {
            "description": "Successful response"
          }
        },
        "description": "Searches for books by a given query. Accepts a POST request with search parameters in the request body and returns a list of matching books from the BiblioReads database.",
        "operationId": "postApiSearchBooks",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "queryURL"
                ],
                "properties": {
                  "queryURL": {
                    "type": "string",
                    "format": "uri"
                  }
                }
              },
              "example": {
                "queryURL": "https://www.goodreads.com/search?q=powerless"
              }
            }
          }
        },
        "x-fern-sdk-method-name": "search-books"
      }
    },
    "/api/series-scraper": {
      "post": {
        "summary": "series-scraper",
        "responses": {
          "200": {
            "description": "Successful response"
          }
        },
        "description": "Scrapes information about a book series. Accepts a POST request with a series identifier and returns details such as the series title, book order, and individual book entries.",
        "operationId": "postApiSeries-scraper",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "queryURL"
                ],
                "properties": {
                  "queryURL": {
                    "type": "string",
                    "format": "uri"
                  }
                }
              },
              "example": {
