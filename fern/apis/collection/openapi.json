              }
            }
          }
        },
        "x-fern-sdk-method-name": "series-scraper"
      }
    },
    "/api/reviews-scraper": {
      "post": {
        "summary": "reviews-scraper",
        "responses": {
          "200": {
            "description": "Successful response"
          }
        },
        "description": "Scrapes reviews for a specified book. Accepts a POST request with book identifiers in the body and returns scraped review data from the source.",
        "operationId": "postApiReviews-scraper",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "resourceID",
                  "legacyBookID"
                ],
                "properties": {
                  "resourceID": {
                    "type": "string"
                  },
                  "legacyBookID": {
                    "type": "integer"
                  },
                  "nextPageToken": {
                    "type": [
                      "null"
                    ]
                  }
                }
              },
              "example": {
                "resourceID": "kca://work/amzn1.gr.work.v1.U_UP9GjBCWvFz0W1V-A5fQ",
                "legacyBookID": 11387515,
                "nextPageToken": null
              }
            }
          }
        },
        "x-fern-sdk-method-name": "reviews-scraper"
      }
    },
    "/api/similar-scraper": {
      "post": {
        "summary": "similar-scraper",
